 "format_data": "[]",
 "html": "<div class=\"labels-container\">\n    {% for item in doc.items %}\n        {% if item.status != 'Cancelled' %}\n            {% set carton = frappe.get_doc('Carton QR', item.carton_no) %}\n            {% set qr_svg = generate_qr_svg(carton.signed_data) %}\n\n            <div class=\"label-box\">\n                <div class=\"header\">\n                    <div class=\"item-name\">{{ carton.item }}</div>\n                </div>\n\n                <div class=\"meta-row\">\n                    <div>\n                        <div class=\"label-text\">Batch No</div>\n                        <div class=\"value-text\">{{ doc.name }}</div>\n                    </div>\n                    <div style=\"text-align: right;\">\n                        <div class=\"label-text\">Carton No</div>\n                        <div class=\"value-text\" style=\"font-family: monospace;\">{{ carton.carton_no }}</div>\n                    </div>\n                </div>\n\n                <div class=\"qr-container\">\n                    {{ qr_svg }}\n                </div>\n\n                <div class=\"bottom-row\">\n                    <div class=\"qty-box\">\n                        <span class=\"qty-val\">{{ carton.qty }}</span>\n                        <span class=\"uom-val\">{{ carton.uom or '' }}</span>\n                    </div>\n                </div>\n            </div>\n        {% endif %}\n    {% endfor %}\n</div>\n\n<style>\n@page { size: A4; margin: 0; }\nbody { margin: 0; padding: 0; background: white; }\n\n.labels-container {\n    display: grid;\n    grid-template-columns: 105mm 105mm;\n    grid-auto-rows: 99mm;\n    width: 210mm;\n    margin: auto;\n}\n\n.label-box {\n    width: 105mm;\n    height: 99mm;\n    padding: 8mm;\n    box-sizing: border-box;\n    border-right: 1px dashed #eee;\n    border-bottom: 1px dashed #eee;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    page-break-inside: avoid;\n}\n\n.header {\n    text-align: center;\n    border-bottom: 2px solid #333;\n    padding-bottom: 2mm;\n}\n\n.item-name {\n    font-size: 20pt;\n    font-weight: 900;\n    text-transform: uppercase;\n    line-height: 1.1;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n}\n\n.meta-row {\n    display: flex;\n    justify-content: space-between;\n    margin-top: 3mm;\n}\n\n.label-text {\n    font-size: 8pt;\n    color: #666;\n    text-transform: uppercase;\n    font-weight: 700;\n}\n\n.value-text {\n    font-size: 11pt;\n    font-weight: 700;\n}\n\n.qr-container {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    flex-grow: 1;\n    padding: 2mm;\n}\n\nsvg {\n    width: 200px !important;\n    height: 200px !important;\n    display: block;\n}\n\n.bottom-row {\n    border-top: 2px solid #333;\n    padding-top: 2mm;\n    text-align: center;\n}\n\n.qty-val {\n    font-size: 32pt;\n    font-weight: 900;\n}\n\n.uom-val {\n    font-size: 14pt;\n    font-weight: 700;\n    color: #666;\n    margin-left: 1mm;\n}\n\n@media print {\n    .label-box:nth-child(2n) { border-right: none; }\n    .label-box:nth-child(6n) { page-break-after: always; }\n}\n</style>",
