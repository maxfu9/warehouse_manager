 "format_data": "[]",
 "html": "<div class=\"labels-container\">\n    {% for item in doc.items %}\n        {% if item.status != 'Cancelled' and item.carton_no %}\n            {% set carton = frappe.get_doc('Carton QR', item.carton_no) %}\n            {% set item_name = frappe.db.get_value('Item', carton.item, 'item_name') or carton.item %}\n\n            <div class=\"label-box\">\n                <table class=\"label-grid\" cellspacing=\"0\" cellpadding=\"0\">\n                    <tr>\n                        <td class=\"label-id\">{{ carton.carton_no }}</td>\n                    </tr>\n                    <tr>\n                        <td class=\"qr-cell\">\n                            <div class=\"qr-box\">\n                                <img\n                                    src=\"{{ generate_qr_png_data_uri(carton.signed_data or carton.name, 10) }}\"\n                                    alt=\"{{ carton.carton_no }}\"\n                                    class=\"qr-image\"\n                                >\n                            </div>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"product-block\">\n                            <div class=\"product-name\">{{ item_name }}</div>\n                            <div class=\"product-qty\">{{ carton.qty }}{% if carton.uom %} {{ carton.uom }}{% endif %}</div>\n                        </td>\n                    </tr>\n                </table>\n            </div>\n        {% endif %}\n    {% endfor %}\n</div>\n\n<style>\n@page {\n    size: A4;\n    margin: 0;\n}\n\nbody {\n    margin: 0;\n    padding: 0;\n    background: #ffffff;\n    font-family: Arial, \"Helvetica Neue\", sans-serif;\n    -webkit-print-color-adjust: exact;\n    print-color-adjust: exact;\n}\n\n.labels-container {\n    width: 210mm;\n    margin: 0 auto;\n}\n\n.label-box {\n    width: 210mm;\n    height: 148.5mm;\n    box-sizing: border-box;\n    padding: 6mm 10mm 5mm;\n    background: #ffffff;\n    page-break-inside: avoid;\n    border-bottom: 1px solid #d4d4d4;\n}\n\n.label-grid {\n    width: 100%;\n    height: 100%;\n    border-collapse: collapse;\n    table-layout: fixed;\n}\n\n.label-id {\n    height: 16mm;\n    font-size: 24pt;\n    font-weight: 900;\n    line-height: 1;\n    letter-spacing: -0.6px;\n    color: #000000;\n    text-align: center;\n    vertical-align: top;\n    padding: 0 0 2mm;\n}\n\n.qr-cell {\n    height: 92mm;\n    vertical-align: middle;\n    text-align: center;\n}\n\n.qr-box {\n    width: 78mm;\n    height: 78mm;\n    margin: 0 auto;\n    background: #ffffff;\n    line-height: 0;\n}\n\n.qr-image {\n    width: 78mm;\n    height: 78mm;\n    display: block;\n    margin: 0 auto;\n}\n\n.product-block {\n    height: 26mm;\n    text-align: center;\n    vertical-align: top;\n    padding-top: 1mm;\n}\n\n.product-name {\n    font-size: 35pt;\n    font-weight: 900;\n    line-height: 1;\n    text-transform: uppercase;\n    letter-spacing: -0.5px;\n    color: #000000;\n    word-break: break-word;\n}\n\n.product-qty {\n    margin-top: 1.2mm;\n    font-size: 25pt;\n    font-weight: 800;\n    line-height: 1.1;\n    text-transform: uppercase;\n    color: #000000;\n}\n\n@media print {\n    .label-box:nth-child(2n) {\n        page-break-after: always;\n    }\n}\n</style>\n",
 "is_standard": "Yes",
 "line_breaker": "None",
